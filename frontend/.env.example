# Copy this to .env.local for local dev
# For Vercel: add these in Project Settings → Environment Variables

# PHP backend WebSocket URL (get this after deploying to Render)
VITE_WS_URL=wss://your-app.onrender.com

# PHP backend REST API URL (same Render URL, https)
VITE_API_URL=https://your-app.onrender.com
